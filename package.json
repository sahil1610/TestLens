{
  "name": "testlens-playwright",
  "version": "0.2.0",
  "description": "Lightweight Playwright reporter that summarizes why tests failed.",
  "license": "MIT",
  "author": "TestLens Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahil1610/TestLens.git"
  },
  "homepage": "https://github.com/sahil1610/TestLens#readme",
  "bugs": {
    "url": "https://github.com/sahil1610/TestLens/issues"
  },
  "keywords": [
    "playwright",
    "reporter",
    "testing",
    "ci",
    "debugging"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "testlens-playwright": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "test": "vitest run",
    "test:pw": "npm run build && playwright test -c playwright.e2e.config.ts",
    "test:integration": "npm run build && node scripts/run-playwright-integration.js"
  },
  "peerDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "default": "./dist/fixtures.js"
    },
    "./integrations": {
      "types": "./dist/integrations/register.d.ts",
      "default": "./dist/integrations/register.js"
    }
  }
}
